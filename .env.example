NODE_ENV=development
APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-32-character-secret
AWS_REGION=us-east-1
# Use file locally and dynamo in AWS Amplify/production.
PERSISTENCE_DRIVER=file
DEV_DATA_FILE=.local/pestimator-dev.json
# Optional local-only fallback login. Ignored in production.
LOCAL_DEV_LOGIN_ENABLED=false
LOCAL_DEV_LOGIN_EMAIL=
LOCAL_DEV_LOGIN_PASSWORD=
COGNITO_CLIENT_ID=
COGNITO_USER_POOL_ID=
# SES_FROM_EMAIL must be verified in SES. Use a verified domain before production launch.
SES_FROM_EMAIL=
SES_FROM_NAME=Pestimator
S3_ATTACHMENTS_BUCKET=
# Stripe invoice payment links and webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
Pestimator_STRIPE_PRICE_ID=
# These can be set manually in Amplify environment variables or read from amplify_outputs.json custom.dynamodbTables.
TABLE_ORGANIZATIONS=
TABLE_BRANCHES=
TABLE_ORGANIZATION_MEMBERSHIPS=
TABLE_CUSTOMERS=
TABLE_CUSTOMER_CONTACTS=
TABLE_PROPERTIES=
TABLE_SERVICE_TEMPLATES=
TABLE_RATE_CARDS=
TABLE_RATE_RULES=
TABLE_QUOTES=
TABLE_QUOTE_REVISIONS=
TABLE_QUOTE_LINES=
TABLE_QUOTE_ATTACHMENTS=
TABLE_QUOTE_ACCEPTANCES=
TABLE_INVOICES=
TABLE_INVOICE_LINES=
TABLE_PAYMENTS=
TABLE_EMAIL_MESSAGES=
TABLE_EMAIL_EVENTS=
TABLE_PORTAL_ACCESS_TOKENS=
TABLE_SUBSCRIPTIONS=
TABLE_AUDIT_EVENTS=
